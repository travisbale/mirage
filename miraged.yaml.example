domain: phish.example.com
external_ipv4: 1.2.3.4

# Optional — defaults shown
https_port: 443
dns_port: 53
db_path: /var/lib/mirage/data.db
phishlets_dir: /etc/mirage/phishlets
redirectors_dir: /etc/mirage/redirectors
autocert: true

# Optional — JS obfuscation of injected scripts (requires Node.js >= 18 on the server)
# Run `make sidecar-install` to install the sidecar npm dependencies before enabling.
# obfuscator:
#   enabled: true
#   sidecar_dir: /etc/mirage/obfuscator/sidecar
#   node_path: ""          # empty = search PATH
#   request_timeout: 5s
#   max_concurrent: 4

# Optional — remove if not using a DNS provider for automatic record management
dns_providers:
  - alias: cf-main
    provider: cloudflare
    settings:
      api_token: YOUR_TOKEN
